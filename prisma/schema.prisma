// Enterprise Smart Luxury Mall Management System - Prisma Schema
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  SUPER_ADMIN
  TENANT
  SECURITY
  STAFF
  VISITOR
}

enum ShopCategory {
  AUTOMOBILE
  FASHION
  BEAUTY
  BAGS
  JEWELLERY
  FOOD
  ELECTRONICS
  ENTERTAINMENT
}

enum ShopStatus {
  OCCUPIED
  VACANT
  UNDER_RENOVATION
  AUCTION_OPEN
}

enum InvoiceStatus {
  DRAFT
  PENDING
  PAID
  OVERDUE
  CANCELLED
}

enum ParkingType {
  STANDARD
  VALET
  EV_CHARGING
  HANDICAPPED
  VIP
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  ON_LEAVE
}

enum EmergencyType {
  FIRE
  MEDICAL
  SECURITY
  EVACUATION
}

enum BidStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  passwordHash  String
  name          String
  role          Role           @default(VISITOR)
  phone         String?
  avatar        String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  tenantProfile Tenant?
  staffProfile  Staff?
  auditLogs     AuditLog[]
  notifications Notification[]
  bids          ShopBid[]
}

model Tenant {
  id             String    @id @default(uuid())
  userId         String    @unique
  user           User      @relation(fields: [userId], references: [id])
  companyName    String
  taxId          String
  contactPerson  String
  phone          String
  agreementStart DateTime
  agreementEnd   DateTime
  documents      Json?
  shops          Shop[]
  invoices       Invoice[]
}

model Shop {
  id           String        @id @default(uuid())
  shopNumber   String        @unique
  name         String
  category     ShopCategory
  floor        Int
  areaSqFt     Float
  status       ShopStatus    @default(OCCUPIED)
  logoUrl      String?
  phone        String?
  description  String?
  tenantId     String?
  tenant       Tenant?       @relation(fields: [tenantId], references: [id])
  monthlyRent  Float
  invoices     Invoice[]
  bids         ShopBid[]
  foodItems    FoodItem[]
}

model Invoice {
  id             String        @id @default(uuid())
  invoiceNumber  String        @unique
  tenantId       String
  tenant         Tenant        @relation(fields: [tenantId], references: [id])
  shopId         String
  shop           Shop          @relation(fields: [shopId], references: [id])
  month          String
  baseRent       Float
  maintenanceFee Float
  electricityFee Float
  waterFee       Float
  parkingFee     Float
  gstAmount      Float
  lateFee        Float         @default(0)
  totalAmount    Float
  status         InvoiceStatus @default(PENDING)
  dueDate        DateTime
  paidAt         DateTime?
  createdAt      DateTime      @default(now())
  payments       Payment[]
}

model Payment {
  id            String   @id @default(uuid())
  invoiceId     String
  invoice       Invoice  @relation(fields: [invoiceId], references: [id])
  paymentMethod String
  transactionId String   @unique
  amount        Float
  paidAt        DateTime @default(now())
}

model Staff {
  id              String           @id @default(uuid())
  userId          String           @unique
  user            User             @relation(fields: [userId], references: [id])
  department      String
  designation     String
  shiftStart      String
  shiftEnd        String
  salary          Float
  assignedZone    String?
  faceEmbedding   String?
  attendances     Attendance[]
  gpsLogs         GPSLog[]
  taskAssignments TaskAssignment[]
}

model Attendance {
  id          String           @id @default(uuid())
  staffId     String
  staff       Staff            @relation(fields: [staffId], references: [id])
  timestamp   DateTime         @default(now())
  status      AttendanceStatus @default(PRESENT)
  confidence  Float
  liveness    Boolean          @default(true)
  photoUrl    String?
  isVerified  Boolean          @default(true)
}

model GPSLog {
  id        String   @id @default(uuid())
  staffId   String
  staff     Staff    @relation(fields: [staffId], references: [id])
  latitude  Float
  longitude Float
  floor     Int
  zone      String
  isSos     Boolean  @default(false)
  timestamp DateTime @default(now())
}

model TaskAssignment {
  id          String   @id @default(uuid())
  staffId     String
  staff       Staff    @relation(fields: [staffId], references: [id])
  title       String
  description String
  location    String
  isCompleted Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model ParkingSlot {
  id          String       @id @default(uuid())
  slotNumber  String       @unique
  floor       Int
  zone        String
  type        ParkingType  @default(STANDARD)
  isOccupied  Boolean      @default(false)
  vehicleLogs VehicleLog[]
}

model VehicleLog {
  id          String      @id @default(uuid())
  plateNumber String
  slotId      String
  slot        ParkingSlot @relation(fields: [slotId], references: [id])
  entryTime   DateTime    @default(now())
  exitTime    DateTime?
  totalFee    Float       @default(0)
  isPaid      Boolean     @default(false)
}

model Camera {
  id         String   @id @default(uuid())
  name       String
  location   String
  zone       String
  streamUrl  String
  isOnline   Boolean  @default(true)
  resolution String   @default("1080p")
  alerts     CameraAlert[]
}

model CameraAlert {
  id        String   @id @default(uuid())
  cameraId  String
  camera    Camera   @relation(fields: [cameraId], references: [id])
  type      String
  message   String
  timestamp DateTime @default(now())
}

model Event {
  id          String   @id @default(uuid())
  title       String
  description String
  bannerUrl   String
  location    String
  floor       Int
  startDate   DateTime
  endDate     DateTime
  category    String
}

model Coupon {
  id             String    @id @default(uuid())
  code           String    @unique
  title          String
  discountPct    Float
  maxDiscount    Float
  validUntil     DateTime
  shopName       String
  qrCodeUrl      String?
}

model Restaurant {
  id        String     @id @default(uuid())
  name      String
  cuisine   String
  cuisineType String   @default("Multi")
  rating    Float
  logoUrl   String
  foodItems FoodItem[]
}

model FoodItem {
  id           String     @id @default(uuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  shopId       String?
  shop         Shop?      @relation(fields: [shopId], references: [id])
  name         String
  price        Float
  category     String
  imageUrl     String
  isVeg        Boolean    @default(true)
}

model ConciergeRequest {
  id          String   @id @default(uuid())
  type        String
  userEmail   String
  details     Json
  status      String   @default("PENDING")
  otp         String?
  createdAt   DateTime @default(now())
}

model EnergyUsage {
  id               String   @id @default(uuid())
  timestamp        DateTime @default(now())
  electricityKwh   Float
  waterLiters      Float
  hvacKw           Float
  carbonFootprintKg Float
  floor            Int
}

model ShopBid {
  id        String    @id @default(uuid())
  shopId    String
  shop      Shop      @relation(fields: [shopId], references: [id])
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  bidAmount Float
  status    BidStatus @default(PENDING)
  createdAt DateTime  @default(now())
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  details   String
  ipAddress String?
  timestamp DateTime @default(now())
}
